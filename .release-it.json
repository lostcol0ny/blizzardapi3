{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "push": false
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "sed -i '0,/^version = \".*\"/{s/^version = \".*\"/version = \"${version}\"/}' pyproject.toml"
    ]
  }
}
